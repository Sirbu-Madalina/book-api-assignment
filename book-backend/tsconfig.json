{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "target": "es2016",
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "sourceMap": true,
    "outDir": "dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": false,
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true
  },
  "include": ["./src", "./playwright.config.ts", "./tests"],
  "exclude": ["node_modules/**/*"]
}